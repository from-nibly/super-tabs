// Color-rich Super Tabs layout

layout {
    pane split_direction="vertical" {
        pane size=32 borderless=true {
            plugin location="file:/Users/jordan/.config/zellij/plugins/super-tabs.wasm" {
                columns "branch,status,owner,title"
                column_branch "resize=trunc:end:hard:10;style=#[fg=accent]"
                column_status "resize=trunc:end:hard:12;style=#[fg=yellow]"
                column_owner "resize=trunc:end:hard:10;style=#[fg=tertiary]"
                column_title "resize=trunc:end:flow:5;style=#[fg=none]"
                indicator_active "*"
                indicator_fullscreen "#[fg=error]F"
                indicator_sync "#[fg=tertiary]S"
                border ""
                padding_top 1
            }
        }
        pane borderless=false focus=true
    }

    pane size=2 borderless=true {
        plugin location="zellij:status-bar"
    }
}
