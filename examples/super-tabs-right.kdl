// Super Tabs on the RIGHT side
// Usage: zellij --layout examples/super-tabs-right.kdl

keybinds {
    shared {
        bind "Alt s" {
            MessagePlugin "file:/Users/jordan/.config/zellij/plugins/super-tabs.wasm" {
                name "toggle_selectable"
            }
        }
    }
}

layout {
    pane split_direction="vertical" {
        pane
        pane size=30 borderless=true {
            plugin location="file:/Users/jordan/.config/zellij/plugins/super-tabs.wasm" {
                columns ""
                column_service "resize=trunc:end:hard:12;style=#[fg=secondary]"
                column_owner "resize=trunc:end:hard:10;style=#[fg=tertiary]"
                column_title "resize=trunc:end:flow:4;style=#[fg=none]"
                border "#[fg=dim]│"
            }
        }
    }
    pane size=1 borderless=true {
        plugin location="zellij:status-bar"
    }
}
